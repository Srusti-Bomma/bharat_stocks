# Copy to .env and fill values
# MySQL connection string: mysql+pymysql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/bharat_stocks

# App
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# APIs
INDIAN_API_KEY=
# Default used by code is https://stock.indianapi.in
INDIAN_API_BASE_URL=https://stock.indianapi.in
INDIAN_API_AUTH_MODE=bearer  # bearer or query
INDIAN_API_QUERY_PARAM=apikey
GNEWS_API_KEY=

# Google OAuth (used by /auth/google)
GOOGLE_CLIENT_ID=

# Power BI
POWERBI_PUSH_URL=
POWERBI_EMBED_URL=
